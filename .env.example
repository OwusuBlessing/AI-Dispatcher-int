# LLM Provider (openai | anthropic | groq | google)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# Geocoding
GEOCODER_PROVIDER=nominatim
NOMINATIM_USER_AGENT=ai-dispatcher/0.1.0

# Paths
DATA_DIR=data
CACHE_DIR=data/cache
OUTPUT_DIR=src/outputs

# Logging
LOG_LEVEL=INFO
